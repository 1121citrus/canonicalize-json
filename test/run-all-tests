set -euo pipefail

whereami=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")

# Default to the tag produced by a local `./build` run (VERSION=dev).
# CI overrides this by setting TAG before invoking this script.
export TAG="${TAG:-dev}"

status=0
while read -r testfile; do
    echo "Running test: ${testfile}"
    bash "${testfile}" || status=1
done < <(find "${whereami}/bin" -mindepth 1 -maxdepth 1 -type f | sort)
exit $status
